#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# CONFIGURATION — edit this section to adapt for your setup
# ============================================================

# Vault paths (no trailing slash)
WORK_VAULT="${HOME}/obsidian-work"
PERSONAL_VAULT="${HOME}/obsidian"

# Folders within each vault available for filing (pipe-separated display|path pairs)
# Format: "Display Name|relative/path/in/vault"
# Listed in seed order (most relevant first); DB usage stats will reorder at runtime.
WORK_FOLDERS=(
  "Research|Research"
  "Labs|Labs"
  "Knowledge|Knowledge"
  "Projects|Projects"
  "Read later|Read later"
)

PERSONAL_FOLDERS=(
  "Knowledge|Knowledge"
  "plans|plans"
  "Inbox|Inbox"
)

# SQLite database path
DB_PATH="${HOME}/.local/share/save-link/links.db"

# claude CLI command (used only for 'summarize' action)
CLAUDE_CMD="claude"

# fzf binary path
FZF_CMD="fzf"

# ============================================================
# END CONFIGURATION
# ============================================================

check_deps() {
  local missing=()
  for cmd in fzf sqlite3 curl; do
    command -v "$cmd" &>/dev/null || missing+=("$cmd")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: missing required dependencies: ${missing[*]}"
    echo "Install them and try again."
    exit 1
  fi
}

db_init() {
  mkdir -p "$(dirname "$DB_PATH")"
  sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS links (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    url         TEXT NOT NULL,
    title       TEXT,
    file_path   TEXT NOT NULL,
    folder      TEXT NOT NULL,
    vault       TEXT NOT NULL,
    action      TEXT NOT NULL,
    saved_at    TEXT NOT NULL DEFAULT (date('now'))
);
CREATE UNIQUE INDEX IF NOT EXISTS idx_links_url ON links(url);
CREATE TABLE IF NOT EXISTS folder_defaults (
    folder          TEXT PRIMARY KEY,
    default_action  TEXT NOT NULL,
    sample_count    INTEGER NOT NULL DEFAULT 0,
    updated_at      TEXT NOT NULL DEFAULT (date('now'))
);
SQL
}

duplicate_check() {
  local url="$1"
  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT file_path FROM links WHERE url = '$(echo "$url" | sed "s/'/''/g")' LIMIT 1;")
  if [[ -n "$existing" ]]; then
    echo "⚠  Already saved: $existing"
    printf "Save again? [y/N] "
    read -r answer </dev/tty
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      echo "Aborted."
      exit 0
    fi
  fi
}

CURL_OPTS=(-s --max-time 8 --connect-timeout 5)

resolve_title_atlassian() {
  local url="$1"
  local title=""

  # Confluence page — extract page ID from URL
  if [[ "$url" =~ /wiki/ ]]; then
    local page_id
    page_id=$(echo "$url" | grep -oE '/pages/[0-9]+' | grep -oE '[0-9]+' | head -1)
    if [[ -n "$page_id" ]]; then
      title=$(curl "${CURL_OPTS[@]}" \
        -u "${ATLASSIAN_USER_EMAIL}:${ATLASSIAN_API_TOKEN}" \
        -H "Accept: application/json" \
        "${ATLASSIAN_SITE_URL}/wiki/rest/api/content/${page_id}" \
        2>/dev/null \
        | grep -o '"title":"[^"]*"' | head -1 | sed 's/"title":"//;s/"//')
    fi
  fi

  # Jira issue — extract issue key from URL (e.g. /browse/PROJ-123)
  if [[ -z "$title" && "$url" =~ /browse/([A-Z]+-[0-9]+) ]]; then
    local issue_key="${BASH_REMATCH[1]}"
    title=$(curl "${CURL_OPTS[@]}" \
      -u "${ATLASSIAN_USER_EMAIL}:${ATLASSIAN_API_TOKEN}" \
      -H "Accept: application/json" \
      "${ATLASSIAN_SITE_URL}/rest/api/3/issue/${issue_key}?fields=summary" \
      2>/dev/null \
      | grep -o '"summary":"[^"]*"' | head -1 | sed 's/"summary":"//;s/"//')
    [[ -n "$title" ]] && title="${issue_key}: ${title}"
  fi

  echo "$title"
}

is_atlassian_url() {
  local url="$1"
  [[ -n "${ATLASSIAN_SITE_URL:-}" ]] || return 1
  local domain
  domain=$(echo "$ATLASSIAN_SITE_URL" | sed 's|https\?://||;s|/.*||')
  [[ "$url" == *"$domain"* ]]
}

resolve_title() {
  local url="$1"
  local title=""

  if is_atlassian_url "$url"; then
    echo "Fetching title via Atlassian API..." >&2
    title=$(resolve_title_atlassian "$url")
  else
    title=$(curl "${CURL_OPTS[@]}" -L "$url" 2>/dev/null \
      | grep -o '<title[^>]*>[^<]*</title>' \
      | sed 's/<[^>]*>//g' \
      | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
      | head -1)
  fi

  # Filter out known auth-wall / error page titles
  case "$title" in
    ""|"Page not found"*|"Sign in"*|"Log in"*|"Login"*|"403"*|"401"*|"Access Denied"*)
      title=""
      ;;
  esac

  # Prompt for manual title if still empty
  if [[ -z "$title" ]]; then
    printf "Could not fetch title automatically.\nTitle: " >&2
    read -r title </dev/tty
  fi

  # Final fallback to domain
  if [[ -z "$title" ]]; then
    title=$(echo "$url" | sed 's|https\?://||;s|/.*||')
  fi

  echo "$title"
}

slugify() {
  local input="$1"
  echo "$input" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9 -]//g' \
    | sed -E 's/ +/-/g' \
    | sed -E 's/-+/-/g' \
    | cut -c1-60 \
    | sed 's/-$//'
}

build_folder_list() {
  local vault_key="$1"
  shift
  local folders=("$@")

  # Get usage counts from DB
  local counts
  counts=$(sqlite3 "$DB_PATH" \
    "SELECT folder, COUNT(*) as cnt FROM links WHERE vault='$vault_key' GROUP BY folder;" \
    2>/dev/null || true)

  # Build display list: prepend count (zero-padded for sort) to each entry
  local sorted=()
  for entry in "${folders[@]}"; do
    local display="${entry%%|*}"
    local rel_path="${entry##*|}"
    local count=0
    if echo "$counts" | grep -q "^${display}|"; then
      count=$(echo "$counts" | grep "^${display}|" | cut -d'|' -f2)
    fi
    sorted+=("$(printf '%05d|%s|%s' "$count" "$display" "$rel_path")")
  done

  # Sort descending by count, strip the count prefix for display
  printf '%s\n' "${sorted[@]}" | sort -rn | sed 's/^[0-9]*|//'
}

usage() {
  echo "Usage: save-link <url>"
  echo ""
  echo "Saves a URL as a structured markdown note into your Obsidian vault."
  echo ""
  echo "Dependencies: fzf, sqlite3, curl"
  echo "Optional:     claude CLI (required for 'Fetch + summarize' action)"
  exit 1
}

[[ $# -lt 1 ]] && usage
URL="$1"
check_deps
db_init
duplicate_check "$URL"

echo "Fetching title..."
TITLE=$(resolve_title "$URL")
echo "Title: $TITLE"
SLUG=$(slugify "$TITLE")
DATE=$(date +%Y-%m-%d)
FILENAME="${DATE}-${SLUG}.md"

# Vault selection
VAULT_CHOICE=$(printf "Work\nPersonal" | "$FZF_CMD" --prompt="Vault > " --height=5 --no-info)
[[ -z "$VAULT_CHOICE" ]] && { echo "Cancelled."; exit 0; }

if [[ "$VAULT_CHOICE" == "Work" ]]; then
  VAULT_KEY="work"
  VAULT_PATH="$WORK_VAULT"
  FOLDER_LIST=("${WORK_FOLDERS[@]}")
else
  VAULT_KEY="personal"
  VAULT_PATH="$PERSONAL_VAULT"
  FOLDER_LIST=("${PERSONAL_FOLDERS[@]}")
fi

# Folder selection
FOLDER_ENTRIES=$(build_folder_list "$VAULT_KEY" "${FOLDER_LIST[@]}")

FOLDER_CHOICE=$(printf '%s\n+ New location...' "$(echo "$FOLDER_ENTRIES" | awk -F'|' '{print $1}')" \
  | "$FZF_CMD" --prompt="Folder > " --height=15 --no-info)
[[ -z "$FOLDER_CHOICE" ]] && { echo "Cancelled."; exit 0; }

# Resolve the relative path for the chosen display name
if [[ "$FOLDER_CHOICE" == "+ New location..." ]]; then
  printf "Relative path in vault (e.g. Research/New Topic): "
  FOLDER_REL=$(</dev/tty)
  FOLDER_REL="${FOLDER_REL%/}"  # strip trailing slash
  [[ -z "$FOLDER_REL" ]] && { echo "Cancelled."; exit 0; }
  FOLDER_CHOICE="$FOLDER_REL"
else
  FOLDER_REL=$(echo "$FOLDER_ENTRIES" | grep -F "${FOLDER_CHOICE}|" | head -1 | cut -d'|' -f2)
fi
FOLDER_ABS="${VAULT_PATH}/${FOLDER_REL}"

# Determine learned default for this folder (if any)
FOLDER_DEFAULT=$(sqlite3 "$DB_PATH" \
  "SELECT default_action FROM folder_defaults WHERE folder='$(echo "$FOLDER_CHOICE" | sed "s/'/''/g")' LIMIT 1;" \
  2>/dev/null || true)

ACTIONS=(
  "link-only|File link only"
  "summarize|Fetch + summarize (requires claude CLI)"
  "excerpt|Fetch + excerpt"
  "annotate|Add my note"
)

# Build fzf input — put learned default first if exists
ACTION_DISPLAY=()
for a in "${ACTIONS[@]}"; do
  ACTION_DISPLAY+=("${a##*|}")
done

if [[ -n "$FOLDER_DEFAULT" ]]; then
  # Find the label for the default action key and move it to top
  DEFAULT_LABEL=""
  for a in "${ACTIONS[@]}"; do
    if [[ "${a%%|*}" == "$FOLDER_DEFAULT" ]]; then
      DEFAULT_LABEL="${a##*|}"
      break
    fi
  done
  # Reorder: default first, rest after
  ORDERED_LABELS=("$DEFAULT_LABEL")
  for label in "${ACTION_DISPLAY[@]}"; do
    [[ "$label" != "$DEFAULT_LABEL" ]] && ORDERED_LABELS+=("$label")
  done
  ACTION_LIST=$(printf '%s\n' "${ORDERED_LABELS[@]}")
else
  ACTION_LIST=$(printf '%s\n' "${ACTION_DISPLAY[@]}")
fi

ACTION_LABEL=$(echo "$ACTION_LIST" \
  | "$FZF_CMD" --prompt="Action > " --height=8 --no-info)
[[ -z "$ACTION_LABEL" ]] && { echo "Cancelled."; exit 0; }

# Map label back to action key
ACTION_KEY=""
for a in "${ACTIONS[@]}"; do
  if [[ "${a##*|}" == "$ACTION_LABEL" ]]; then
    ACTION_KEY="${a%%|*}"
    break
  fi
done

# Ensure target folder exists
mkdir -p "$FOLDER_ABS"
NOTE_PATH="${FOLDER_ABS}/${FILENAME}"

write_note() {
  local content="$1"
  if [[ -e "$NOTE_PATH" ]]; then
    local base="${NOTE_PATH%.md}"
    local n=1
    while [[ -e "${base}-${n}.md" ]]; do (( n++ )); done
    NOTE_PATH="${base}-${n}.md"
    echo "Note: filename collision, saving as $(basename "$NOTE_PATH")"
  fi
  printf '%s\n' "$content" > "$NOTE_PATH"
}

case "$ACTION_KEY" in
  link-only)
    write_note "# ${TITLE}

**Source:** [${TITLE}](${URL})
**Saved:** ${DATE}
"
    ;;

  annotate)
    echo "Note (press Ctrl-D when done):"
    USER_NOTE=$(cat </dev/tty)
    write_note "# ${TITLE}

**Source:** [${TITLE}](${URL})
**Saved:** ${DATE}

---

## Notes

${USER_NOTE}
"
    ;;

  excerpt)
    echo "Fetching page content..."
    RAW_TEXT=$(curl -sL --max-time 15 "$URL" \
      | perl -0pe 's/<script[^>]*>.*?<\/script>//gsi' \
      | perl -0pe 's/<style[^>]*>.*?<\/style>//gsi' \
      | sed 's/<[^>]*>//g' \
      | sed '/^[[:space:]]*$/d' \
      | tr -s ' \t' ' ' \
      | head -c 2000)
    write_note "# ${TITLE}

**Source:** [${TITLE}](${URL})
**Saved:** ${DATE}

---

## Excerpt

${RAW_TEXT}
"
    ;;

  summarize)
    if ! command -v "$CLAUDE_CMD" &>/dev/null; then
      echo "Error: claude CLI not found. Install it or change CLAUDE_CMD in the config."
      exit 1
    fi
    echo "Fetching and summarizing (this may take a moment)..."
    PAGE_CONTENT=$(curl -sL --max-time 15 "$URL" \
      | perl -0pe 's/<script[^>]*>.*?<\/script>//gsi' \
      | perl -0pe 's/<style[^>]*>.*?<\/style>//gsi' \
      | sed 's/<[^>]*>//g' \
      | sed '/^[[:space:]]*$/d' \
      | tr -s ' \t' ' ' \
      | head -c 8000)

    SUMMARY=$(printf 'Page content:\n\n%s\n' "$PAGE_CONTENT" | "$CLAUDE_CMD" -p "Summarize the following web page content. Output ONLY the markdown body — no code fences, no preamble. Use this exact format:

# ${TITLE}

**Source:** [${TITLE}](${URL})
**Saved:** ${DATE}
**Note:** Summarized via save-link

---

## Summary
<2-3 paragraph summary of the content>

## Key Points
- <key point>
- <key point>
- <key point>")
    write_note "$SUMMARY"
    ;;

  *)
    echo "Error: unknown action: $ACTION_KEY"
    exit 1
    ;;
esac

db_record() {
  local url="$1" title="$2" file_path="$3" folder="$4" vault="$5" action="$6"
  # Escape single quotes for SQLite
  local esc_url="${url//"'"/"''"}"
  local esc_title="${title//"'"/"''"}"
  local esc_path="${file_path//"'"/"''"}"
  local esc_folder="${folder//"'"/"''"}"

  sqlite3 "$DB_PATH" <<SQL
INSERT OR IGNORE INTO links(url, title, file_path, folder, vault, action)
VALUES('${esc_url}', '${esc_title}', '${esc_path}', '${esc_folder}', '${vault}', '${action}');

INSERT INTO folder_defaults(folder, default_action, sample_count, updated_at)
SELECT
  '${esc_folder}',
  action,
  COUNT(*),
  date('now')
FROM links
WHERE folder = '${esc_folder}'
GROUP BY action
ORDER BY COUNT(*) DESC
LIMIT 1
ON CONFLICT(folder) DO UPDATE SET
  default_action = excluded.default_action,
  sample_count   = excluded.sample_count,
  updated_at     = excluded.updated_at;
SQL
}

db_record "$URL" "$TITLE" "$NOTE_PATH" "$FOLDER_CHOICE" "$VAULT_KEY" "$ACTION_KEY"
echo "Saved to $NOTE_PATH"
