#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# CONFIGURATION — edit this section to adapt for your setup
# ============================================================

# Vault paths (no trailing slash)
WORK_VAULT="${HOME}/obsidian-work"
PERSONAL_VAULT="${HOME}/obsidian"

# Folders within each vault available for filing (pipe-separated display|path pairs)
# Format: "Display Name|relative/path/in/vault"
# Listed in seed order (most relevant first); DB usage stats will reorder at runtime.
WORK_FOLDERS=(
  "Research/Security Research|Research/Security Research"
  "Labs/Integration Lab|Labs/Integration Lab"
  "Labs/Threat Lab|Labs/Threat Lab"
  "Labs/DecAIpticon|Labs/DecAIpticon"
  "IDR/detection_coe|IDR/detection_coe"
  "IDR/schema_council|IDR/schema_council"
  "Knowledge|Knowledge"
  "Projects|Projects"
  "AWN|AWN"
  "Read later|Read later"
)

PERSONAL_FOLDERS=(
  "Knowledge|Knowledge"
  "plans|plans"
  "Inbox|Inbox"
)

# SQLite database path
DB_PATH="${HOME}/.local/share/save-link/links.db"

# claude CLI command (used only for 'summarize' action)
CLAUDE_CMD="claude"

# fzf binary path
FZF_CMD="fzf"

# ============================================================
# END CONFIGURATION
# ============================================================

db_init() {
  mkdir -p "$(dirname "$DB_PATH")"
  sqlite3 "$DB_PATH" <<'SQL'
CREATE TABLE IF NOT EXISTS links (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    url         TEXT NOT NULL,
    title       TEXT,
    file_path   TEXT NOT NULL,
    folder      TEXT NOT NULL,
    vault       TEXT NOT NULL,
    action      TEXT NOT NULL,
    saved_at    TEXT NOT NULL DEFAULT (date('now'))
);
CREATE UNIQUE INDEX IF NOT EXISTS idx_links_url ON links(url);
CREATE TABLE IF NOT EXISTS folder_defaults (
    folder          TEXT PRIMARY KEY,
    default_action  TEXT NOT NULL,
    sample_count    INTEGER NOT NULL DEFAULT 0,
    updated_at      TEXT NOT NULL DEFAULT (date('now'))
);
SQL
}

duplicate_check() {
  local url="$1"
  local existing
  existing=$(sqlite3 "$DB_PATH" "SELECT file_path FROM links WHERE url = '$(echo "$url" | sed "s/'/''/g")' LIMIT 1;")
  if [[ -n "$existing" ]]; then
    echo "⚠  Already saved: $existing"
    printf "Save again? [y/N] "
    read -r answer </dev/tty
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      echo "Aborted."
      exit 0
    fi
  fi
}

resolve_title() {
  local url="$1"
  local title
  title=$(curl -sL --max-time 10 "$url" \
    | grep -o '<title[^>]*>[^<]*</title>' \
    | sed 's/<[^>]*>//g' \
    | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
    | head -1)
  # Fallback to domain if no title found
  if [[ -z "$title" ]]; then
    title=$(echo "$url" | sed 's|https\?://||;s|/.*||')
  fi
  echo "$title"
}

slugify() {
  local input="$1"
  echo "$input" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9 -]//g' \
    | sed -E 's/ +/-/g' \
    | sed -E 's/-+/-/g' \
    | cut -c1-60 \
    | sed 's/-$//'
}

usage() {
  echo "Usage: save-link <url>"
  echo ""
  echo "Saves a URL as a structured markdown note into your Obsidian vault."
  echo ""
  echo "Dependencies: fzf, sqlite3, curl"
  echo "Optional:     claude CLI (required for 'Fetch + summarize' action)"
  exit 1
}

[[ $# -lt 1 ]] && usage
URL="$1"

db_init
duplicate_check "$URL"

echo "Fetching title..."
TITLE=$(resolve_title "$URL")
echo "Title: $TITLE"
SLUG=$(slugify "$TITLE")
DATE=$(date +%Y-%m-%d)
FILENAME="${DATE}-${SLUG}.md"

echo "FILENAME=$FILENAME"
